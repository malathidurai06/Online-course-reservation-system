# ============================================================
# Online Course Reservation System - Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# MongoDB Connection String
# Local:  mongodb://localhost:27017/course_reservation
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/course_reservation
MONGO_URI=mongodb+srv://Malathi_durai:2005@cluster0.oequppb.mongodb.net/?appName=Cluster0

# JWT Secret Key (use a long, random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Token Expiry
JWT_EXPIRES_IN=7d

# Server Port
PORT=5000

# Node Environment (development | production)
NODE_ENV=development
